# CET-4 Learning System - Environment Variables

# Backend server port
PORT=3001

# JWT Secret (change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Database path (SQLite)
DB_PATH=./cet4.db

# AI API Key (通义千问 / Qwen) - Optional, falls back to local scoring if not set
DASHSCOPE_API_KEY=

# Server URL for internal API calls
SERVER_URL=http://localhost:3001

# Frontend API URL (for Vite dev proxy or production)
VITE_API_URL=http://localhost:3001
